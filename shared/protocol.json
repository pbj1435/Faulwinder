    { "key": "enabled",        "short": "0005", "type": "bool",   "props": ["read", "write"], "default": true, "desc": "Winding on/off" },
    { "key": "calibration",    "short": "0006", "type": "uint16", "props": ["read", "write"], "default": 0, "min": 0, "max": 65000, "desc": "Measured output speed in centi-RPM (RPM x100); 0 = use theoretical from GEAR_RATIO" },
    { "key": "status",         "short": "0007", "type": "uint8",  "props": ["read", "notify"], "readOnly": true, "desc": "Runtime status code (0 idle, 1 winding, 2 sleeping, 3 fault)" }
